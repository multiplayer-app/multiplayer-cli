{
  "name": "@multiplayer-app/cli",
  "version": "2.0.98",
  "description": "Multiplayer CLI",
  "type": "module",
  "bin": {
    "multiplayer": "./bin/multiplayer.js"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "publish": "bun run scripts/publish.ts",
    "dev": "bun src/index.tsx",
    "test": "bun test src/lib/focus",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' --config eslint.config.js",
    "lint:fix": "eslint 'src/**/*.ts' --config eslint.config.js --fix",
    "prepare": "cd node_modules/bun && node install.js",
    "postversion": "git push && git push --tags",
    "preversion": "npm run lint"
  },
  "packageManager": "pnpm@10.33.0",
  "optionalDependencies": {
    "@multiplayer-app/cli-darwin-arm64": "2.0.97",
    "@multiplayer-app/cli-darwin-x64": "2.0.97",
    "@multiplayer-app/cli-linux-arm64": "2.0.97",
    "@multiplayer-app/cli-linux-x64": "2.0.97",
    "@multiplayer-app/cli-windows-arm64": "2.0.97",
    "@multiplayer-app/cli-windows-x64": "2.0.97"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/multiplayer-app/multiplayer-cli.git"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.89",
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^2.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentui/core": "0.4.2",
    "@opentui/core-darwin-arm64": "0.4.2",
    "@opentui/core-darwin-x64": "0.4.2",
    "@opentui/core-linux-arm64": "0.4.2",
    "@opentui/core-linux-arm64-musl": "0.4.2",
    "@opentui/core-linux-x64": "0.4.2",
    "@opentui/core-linux-x64-musl": "0.4.2",
    "@opentui/core-win32-arm64": "0.4.2",
    "@opentui/core-win32-x64": "0.4.2",
    "@opentui/react": "0.4.2",
    "@sindresorhus/tsconfig": "^8.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/superagent": "8.1.9",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "bun": "1.3.11",
    "commander": "14.0.3",
    "dotenv": "16.0.0",
    "eslint": "10.1.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.3.3",
    "openai": "6.33.0",
    "react": "19.2.4",
    "simple-git": "3.33.0",
    "socket.io-client": "4.8.3",
    "superagent": "10.3.0",
    "turbo": "2.9.14",
    "typescript": "6.0.2",
    "zod": "^4.3.6"
  }
}
